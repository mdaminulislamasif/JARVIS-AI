def _restart_with_login():
    """Re-launch the app with the login screen."""
    root = ctk.CTk()
    root.withdraw()

    def _on_login(session):
        root.destroy()
        _launch_main(session)

    check_and_login(root, _on_login)
    root.mainloop()


def _launch_main(session: dict):
    app = JarvisAntigravity(session)
    app.mainloop()


