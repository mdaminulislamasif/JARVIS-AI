    def start_mic(self):
        if self.is_listening:
            self.log("VOICE", "Already listening. Please wait.")
            return

        self.is_listening = True
        self.set_voice_button(True)
        threading.Thread(target=self.voice_capture, daemon=True).start()

    def set_voice_button(self, listening):
        if not hasattr(self, "voice_btn"):
            return

        if listening:
            self.voice_btn.configure(text="LISTENING", state="disabled", fg_color=self.cyber)
        else:
            self.voice_btn.configure(text="LISTEN", state="normal", fg_color=self.neon)

    def voice_capture(self):
        try:
            self.core.set_state("listening")
            if self.face3d:
                self.face3d.set_state("listening")

            query = self.voice.listen()
            if query != "none":
                self.prefer_bangla_voice = (
                    str(getattr(self.voice, "last_language", "")).lower().startswith("bn")
                    or self.voice.has_bangla(query)
                )
                routed_query = self.normalize_voice_command(query)
                if routed_query != query:
                    self.after(0, lambda q=query, r=routed_query: self.log("VOICE", f"{q} -> {r}"))
                else:
                    self.after(0, lambda q=query: self.log("VOICE", q))
                self.process(routed_query)
            else:
                err = getattr(self.voice, "last_error", "") or "No voice command detected."
                self.after(0, lambda msg=err: self.log("VOICE", msg))
        except Exception as e:
            err = f"Listening failed: {e}"
            self.after(0, lambda msg=err: self.log("VOICE", msg))
        finally:
            self.is_listening = False
            self.after(0, lambda: self.set_voice_button(False))
            self.core.set_state("idle")
            if self.face3d:
                self.face3d.set_state("idle")

    def normalize_voice_command(self, query):
        q = query.strip().lower()
        aliases = {
            "clean": ("ক্লিন", "পরিষ্কার", "সাফ"),
            "workspace": ("ওয়ার্কস্পেস", "কাজ শুরু", "ওয়ার্কস্পেস"),
            "screenshot": ("স্ক্রিনশট", "স্ক্রিন শট", "ছবি তোলো"),
            "wifi": ("ওয়াইফাই", "ওয়াইফাই", "ওয়াই ফাই", "ওয়াই ফাই"),
            "users": ("ইউজার", "ব্যবহারকারী"),
            "devices": ("ডিভাইস", "যন্ত্র"),
            "remote": ("রিমোট",),
            "mobile": ("মোবাইল",),
            "share": ("শেয়ার", "শেয়ার"),
            "disk": ("ডিস্ক", "স্টোরেজ"),
            "battery": ("ব্যাটারি",),
            "uptime": ("আপটাইম", "কতক্ষণ চলছে"),
            "browser": ("ব্রাউজার",),
            "window": ("উইন্ডো",),
            "app help": ("app control", "application control", "robot control", "advanced robot"),
            "router": ("রাউটার",),
            "taskmgr": ("টাস্ক ম্যানেজার", "টাস্কম্যানেজার"),
        }

        for command, words in aliases.items():
            if q == command or any(word in q for word in words):
                return command
        return query

